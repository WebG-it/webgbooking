<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>com_webgbooking</name>
    <author>Marco Galassi (WebG)</author>
    <authorEmail>marco.galassi@webg.it</authorEmail>
    <authorUrl>https://www.webg.it</authorUrl>
    <creationDate>2026-06</creationDate>
    <copyright>(C) 2026 Marco Galassi / WebG</copyright>
    <license>GNU General Public License version 2 or later</license>
    <version>0.2.6</version>
    <description>COM_WEBGBOOKING_XML_DESCRIPTION</description>
    <namespace path="src">WebG\Component\Webgbooking</namespace>
    <administration>
        <menu link="option=com_webgbooking" img="class:default">COM_WEBGBOOKING</menu>
        <submenu>
            <menu link="option=com_webgbooking&amp;view=bookings">COM_WEBGBOOKING_SUBMENU_BOOKINGS</menu>
            <menu link="option=com_webgbooking&amp;view=google">COM_WEBGBOOKING_SUBMENU_GOOGLE</menu>
        </submenu>
        <files folder="admin">
            <folder>services</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
            <folder>language</folder>
            <filename>access.xml</filename>
            <filename>config.xml</filename>
        </files>
        <languages folder="admin/language">
            <language tag="en-GB">en-GB/com_webgbooking.ini</language>
            <language tag="en-GB">en-GB/com_webgbooking.sys.ini</language>
            <language tag="it-IT">it-IT/com_webgbooking.ini</language>
            <language tag="it-IT">it-IT/com_webgbooking.sys.ini</language>
        </languages>
    </administration>
</extension>
